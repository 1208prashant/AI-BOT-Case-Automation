# Slack (create app at https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Salesforce (optional — leave empty to use mock mode)
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
SALESFORCE_CLIENT_ID=your-connected-app-client-id
SALESFORCE_CLIENT_SECRET=your-connected-app-client-secret
SALESFORCE_USERNAME=integration-user@company.com
SALESFORCE_PASSWORD=your-password
SALESFORCE_SECURITY_TOKEN=your-security-token

# OpenAI (optional — leave empty to use rule-based analysis)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App settings
MOCK_SALESFORCE=true
POLL_INTERVAL_SECONDS=15
MOCK_CASE_INTERVAL_SECONDS=45
NOTIFY_SEV3=false
WEBHOOK_PORT=3000
LOG_LEVEL=INFO
